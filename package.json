{
  "name": "observe",
  "author": "",
  "description": "CLI tool for Observe Inc",
  "license": "Apache-2.0",
  "type": "module",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "bin": {
    "observe": "dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "bun run codegen && bun run scripts/build.ts",
    "build:single": "bun run codegen && bun run scripts/build.ts --single",
    "dev": "bun run ifneeded:codegen && bun run src/bin.ts",
    "test": "bun run codegen && bun run typecheck && bun run lint && bun run format && bun test src",
    "test:integration": "bun test integration/ --concurrent --max-concurrency 5 --timeout 10000",
    "typecheck": "tsc",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "ifneeded:codegen": "sh -c '[ -f src/gql/generated/graphql.ts ] && [ -f src/rest/generated/index.ts ] || bun run codegen'",
    "codegen": "bun codegen:gql && bun codegen:rest",
    "codegen:gql": "dotenvx run -- bun graphql-code-generator --config src/gql/gql-codegen.config.ts",
    "codegen:rest": "dotenvx run -- sh -c 'bun openapi-generator-cli generate -c src/rest/config.yaml -i $OBSERVE_OPENAPI_SPEC'"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@stricli/core": "^1.2.7",
    "@vercel/detect-agent": "^1.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.69.1",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.0.0",
    "@openapitools/openapi-generator-cli": "^2.34.0",
    "@types/bun": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
